# ─────────────────────────────────────────────────────────────────
# Ollama — Local Phi-3 Mini (General assistant + Expert Mode critic)
# ─────────────────────────────────────────────────────────────────

# Ollama server endpoint (keep local)
OLLAMA_BASE_URL="http://localhost:11434"

# Model for general conversation, app guidance, and Expert Mode critique
# phi3:mini (3.8 GB) — recommended for GTX 1650 4 GB VRAM
OLLAMA_MODEL="phi3:mini"

# Request timeout in milliseconds
OLLAMA_TIMEOUT="90000"


# ─────────────────────────────────────────────────────────────────
# HuggingFace — Qwen2.5-3B BI Analyst (BI specialist)
# Fine-tuned model: Abhishekygr/qwen2.5-3b-bi-analyst
# ─────────────────────────────────────────────────────────────────

# Your HuggingFace access token (required)
# Create one at: https://huggingface.co/settings/tokens
HF_TOKEN="hf_your_token_here"

# Model ID on HuggingFace Hub
HF_MODEL_ID="Abhishekygr/qwen2.5-3b-bi-analyst"

# Optional: Custom Inference Endpoint URL (paid dedicated endpoint)
# Leave empty to use the free Serverless Inference API
# Example: https://your-endpoint-id.endpoints.huggingface.cloud
HF_ENDPOINT_URL=""

# Max tokens for HF responses (default: 768)
HF_MAX_NEW_TOKENS="768"


# ─────────────────────────────────────────────────────────────────
# Export
# ─────────────────────────────────────────────────────────────────

# Optional folder for exported PDF/PPTX reports
PDF_OUTPUT_DIR="./exports"
